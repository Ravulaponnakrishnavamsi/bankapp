# 🏦 SecureBank Environment Variables Template
# Copy this file to .env and fill in the values

# --- Server Config ---
PORT=5000
NODE_ENV=development

# --- Email Config (NodeMailer) ---
# Use a Gmail App Password, not your regular password
GMAIL_USER=###############
GMAIL_APP_PASSWORD=#####

# --- Business Contact ---
# The site owner who receives the OTPs to share with users
OWNER_EMAIL=ravulaponnakrishnavamsi@gmail.com
# --- Firebase Config (Firestore) ---
# Paste the entire JSON content from your Service Account Key file as a single line
# Example: {"type": "service_account", "project_id": "...", ...}
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}
